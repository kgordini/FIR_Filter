% Save variables %
%%%%%%%%%%%%%%%%%%

save('FIR_coeffs.mat', 'impulse_response','quantized_coeff', ...
    'reconstructed_quant_coeff', 'input_signal', 'golden_output', ...
    'input_bits', 'input_fractional_bits', 'coeff_bits', 'coeff_fractional_bits', ...
    'output_bits', 'output_fractional_bits', 'product_bits', 'accumulator_bits', ...
    'required_acc_bits', 'shift_bits', 'final_tap_number');

fprintf('Saved MATLAB variables to FIR_coeffs.mat\n');
